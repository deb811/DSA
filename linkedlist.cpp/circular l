    void delete(node* &tail,int val){
        //empty list
        if(tail==NULL){
            cout<<"empty"<<endl;
            return;
        }

        //non empty
        node*prev=tail;
        node*currt=prev->next;

        while(currt->data==val){
            prev=currt;
            currt=currt->next;
        }
     
        prev->next=currt->next;
        currt->next=NULL;
        delete currt;
    }


